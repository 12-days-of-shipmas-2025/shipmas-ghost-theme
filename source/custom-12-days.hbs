{{!< default}}
{{!--
================================================================================
CUSTOM-12-DAYS.HBS - Dedicated 12 Days of Shipmas Page
================================================================================

Author: Human Written (https://humanwritten.ai)
License: MIT
Repository: https://github.com/12-days-of-shipmas-2025/shipmas-ghost-theme

Standalone page showing only the 12 Days of Shipmas grid.
Useful for a dedicated /12-days/ URL separate from homepage.

Setup:
1. Create a new Page in Ghost Admin
2. Set the slug to "12-days" (URL: /12-days/)
3. In Page Settings, select Template: "12 Days of Shipmas"
4. Publish the page

Note: Posts must be tagged with "12-days-of-shipmas" to appear.
Unpublished days show as "Coming Soon" with a lock icon.

================================================================================
--}}

{{> "components/header" headerStyle="Small"}}

<main class="gh-main">
    {{!-- 12 Days of Shipmas Grid --}}
    <section class="shipmas-grid-section gh-outer">
        <div class="gh-inner">
            <div class="gh-container-header">
                <h1 class="gh-container-title">12 Days of Shipmas</h1>
            </div>

            <div class="shipmas-grid">
                {{#get "posts" filter="tag:12-days-of-shipmas" limit="12" include="authors,tags" order="published_at asc"}}
                    {{#foreach posts}}
                        <a href="{{url}}" class="shipmas-card revealed" data-day="{{@number}}">
                            <div class="shipmas-card-inner">
                                <span class="shipmas-day-number">Day {{@number}}</span>
                                {{#if feature_image}}
                                    <div class="shipmas-card-image" style="background-image: url('{{feature_image}}')"></div>
                                {{else}}
                                    <div class="shipmas-card-image shipmas-card-placeholder"></div>
                                {{/if}}
                                <div class="shipmas-card-content">
                                    <h3 class="shipmas-card-title">{{title}}</h3>
                                    {{#if custom_excerpt}}
                                        <p class="shipmas-card-excerpt">{{custom_excerpt}}</p>
                                    {{else}}
                                        <p class="shipmas-card-excerpt">{{excerpt words="12"}}</p>
                                    {{/if}}
                                </div>
                            </div>
                        </a>
                    {{/foreach}}
                {{/get}}
            </div>
        </div>
    </section>
</main>

{{!-- JavaScript to fill in locked days --}}
<script>
(function() {
    const grid = document.querySelector('.shipmas-grid');
    if (!grid) return;

    const existingCards = grid.querySelectorAll('.shipmas-card');
    const existingDays = new Set();
    existingCards.forEach(card => {
        const day = parseInt(card.dataset.day);
        if (day) existingDays.add(day);
    });

    const allCards = [];

    for (let day = 1; day <= 12; day++) {
        if (!existingDays.has(day)) {
            const card = document.createElement('div');
            card.className = 'shipmas-card locked';
            card.dataset.day = day;
            card.innerHTML = `
                <div class="shipmas-card-inner">
                    <span class="shipmas-day-number">Day ${day}</span>
                    <div class="shipmas-card-image shipmas-card-locked">
                        <svg class="shipmas-lock-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                    </div>
                    <div class="shipmas-card-content">
                        <h3 class="shipmas-card-title">Coming Soon</h3>
                        <p class="shipmas-card-excerpt">Check back on day ${day}</p>
                    </div>
                </div>
            `;
            allCards.push({ day, card, existing: false });
        }
    }

    existingCards.forEach(card => {
        const day = parseInt(card.dataset.day);
        allCards.push({ day, card, existing: true });
    });

    allCards.sort((a, b) => a.day - b.day);

    grid.innerHTML = '';
    allCards.forEach(({ card }) => grid.appendChild(card));
})();
</script>
