{{!-- Festive Snowflakes & Rockets Animation (until Jan 31) --}}
<div class="snowflakes" id="snowflakes-container"></div>

<script>
(function() {
    // Check if effects should be shown
    const SHIPMAS_END_DATE = new Date(2026, 0, 31, 23, 59, 59);
    const now = new Date();
    const params = new URLSearchParams(window.location.search);
    const showAll = params.get('all') === 'true';
    const isPastEndDate = now > SHIPMAS_END_DATE;

    // Hide effects if past end date or in "all posts" mode
    if (showAll || isPastEndDate) return;

    const container = document.getElementById('snowflakes-container');
    if (!container) return;

    // Snowflakes
    const snowflakeChars = ['❄', '❅', '❆', '✦', '✧', '*', '⁕', '⁑'];
    const snowflakeCount = 40;

    function createSnowflake() {
        const snowflake = document.createElement('span');
        snowflake.className = 'snowflake style-' + (Math.floor(Math.random() * 4) + 1);
        snowflake.textContent = snowflakeChars[Math.floor(Math.random() * snowflakeChars.length)];
        snowflake.style.left = Math.random() * 100 + '%';

        const duration = Math.random() * 15 + 12;
        snowflake.style.animationDuration = duration + 's';
        snowflake.style.animationDelay = -(Math.random() * duration) + 's';
        snowflake.style.opacity = Math.random() * 0.5 + 0.3;

        container.appendChild(snowflake);
    }

    for (let i = 0; i < snowflakeCount; i++) {
        createSnowflake();
    }

    // Rockets - shoot across occasionally
    function launchRocket() {
        const rocket = document.createElement('span');
        rocket.className = 'rocket';
        rocket.textContent = '🚀';

        // Random starting position on left side
        rocket.style.top = (Math.random() * 60 + 20) + '%';

        container.appendChild(rocket);

        // Remove after animation
        rocket.addEventListener('animationend', function() {
            rocket.remove();
        });
    }

    // Launch first rocket after 5-15 seconds, then every 20-40 seconds
    setTimeout(function() {
        launchRocket();
        setInterval(launchRocket, Math.random() * 20000 + 20000);
    }, Math.random() * 10000 + 5000);
})();
</script>
